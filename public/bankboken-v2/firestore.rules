rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isMember(bankbookId) {
      return signedIn()
        && request.auth.uid in get(/databases/$(database)/documents/bankbooks/$(bankbookId)).data.memberIds;
    }

    match /users/{userId} {
      allow create, read, update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /bankbooks/{bankbookId} {
      allow create: if signedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.memberIds == [request.auth.uid];

      allow get: if signedIn();
      allow list: if signedIn() && request.auth.uid in resource.data.memberIds;

      allow update: if signedIn() && (
        request.auth.uid in resource.data.memberIds
        || (
          resource.data.memberIds.size() == 1
          && request.resource.data.memberIds.size() == 2
          && request.auth.uid in request.resource.data.memberIds
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.name == resource.data.name
        )
      );
      allow delete: if signedIn() && request.auth.uid == resource.data.createdBy;

      match /entries/{entryId} {
        allow read, create, update, delete: if isMember(bankbookId);
      }

      match /receipts/{entryId} {
        allow read, delete: if isMember(bankbookId);
        allow create, update: if isMember(bankbookId)
          && request.resource.data.imageData is string
          && request.resource.data.imageData.size() < 850000;
      }
    }

    match /entries/{entryId} {
      // Tillfällig kompatibilitet för nuvarande Helo/Halvis-version.
      // Ta bort denna regel först när den gamla datan har migrerats till v2.
      allow read, write: if true;
    }
  }
}
